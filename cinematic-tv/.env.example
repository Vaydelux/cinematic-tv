# Required: TMDB API Read Access Token
TMDB_ACCESS_TOKEN="your_tmdb_read_access_token"

# Required for production share links and OAuth callback configuration
APP_URL="http://localhost:3000"

# Logging: debug | info | warn | error
LOG_LEVEL="debug"

# Optional: allow GET /api/logs in production
# ENABLE_LOG_API="true"

# Optional: AniList authenticated requests. Public anime catalog works without this.
ANILIST_ACCESS_TOKEN=""

# Optional: Wyzie subtitles
WYZIE_API_KEY=""

# Optional: TheIntroDB authenticated operations
THEINTRODB_API_KEY=""

# Optional: shared cache. Falls back to in-memory cache when unset.
# REDIS_URL="redis://localhost:6379"
# Vercel KV / Upstash style cache variables are also accepted when wired by hosting.
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""

# Optional: comma-separated backend URLs for multi-backend failover
# BACKEND_URLS="https://api1.example.com,https://api2.example.com"

# Optional: Firebase client config for Google sign-in, reviews, sharing, and cloud sync
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# NEXT_PUBLIC_FIREBASE_DATABASE_ID=""
